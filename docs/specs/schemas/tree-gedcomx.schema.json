{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tree-gedcomx.schema.json",
  "title": "Cowork Genealogy tree.gedcomx.json",
  "description": "Simplified GedcomX format. The deliverable file in a genealogy research project — eventually uploads to FamilySearch. See docs/specs/simplified-gedcomx-spec.md for prose explanation and conversion rules.",
  "type": "object",
  "required": ["persons", "relationships", "sources"],
  "additionalProperties": false,
  "properties": {
    "persons": {
      "type": "array",
      "items": { "$ref": "#/$defs/person" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationship" }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_description" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "An identifier, unique within its collection. No shape is enforced. Ids arrive from two places and both are legal: FamilySearch-native ids, which are preserved verbatim (person and source PIDs like `KNS4-P6W`, fact UUIDs), and locally synthesized ids for objects FamilySearch does not identify (names, relationships). The `I`/`N`/`F`/`R`/`S` prefixes in simplified-gedcomx-spec.md are a naming convention for synthesized ids, not a constraint — nothing in the codebase reads meaning out of an id's shape. A person's membership in the FamilySearch tree is carried by `ark`, not by the form of `id`."
    },
    "person": {
      "type": "object",
      "required": ["id", "gender", "names"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "ark": {
          "type": "string",
          "description": "Persistent FamilySearch ARK URL. Flat lift of full GedcomX's identifiers[\"http://gedcomx.org/Persistent\"][0]. See simplified-gedcomx-spec.md §4.6."
        },
        "living": {
          "type": "boolean",
          "description": "True when FamilySearch reports the person as living. `person_read` sets this on every person it returns. Living people must never appear in a committed e2e fixture (FamilySearch ToS); see the living-person gate in eval/harness/e2e/author.py."
        },
        "gender": { "$ref": "enums.schema.json#/$defs/gender" },
        "names": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/name" }
        },
        "facts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fact" }
        }
      }
    },
    "name": {
      "type": "object",
      "required": ["id", "given", "surname"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "preferred": { "type": "boolean", "const": true },
        "given": { "type": "string", "description": "Given name(s). Required; spell an unknown given name as \"\" — the engine's own convention (its living-person stub emits given: \"\")." },
        "surname": { "type": "string" },
        "prefix": { "type": "string", "description": "Name prefix, e.g. `Rev.`. Emitted by person_read when FamilySearch supplies one." },
        "suffix": { "type": "string", "description": "Name suffix, e.g. `Jr.`. Emitted by person_read when FamilySearch supplies one." },
        "type": { "$ref": "enums.schema.json#/$defs/gedcomx_name_type_recommended" },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_reference" }
        }
      }
    },
    "fact": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "$ref": "enums.schema.json#/$defs/gedcomx_fact_type_recommended" },
        "primary": { "type": "boolean", "const": true },
        "date": { "type": "string" },
        "standard_date": { "type": "string" },
        "place": { "type": "string" },
        "standard_place": { "type": "string" },
        "value": { "type": "string" },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_reference" }
        }
      }
    },
    "relationship": {
      "oneOf": [
        { "$ref": "#/$defs/parent_child_relationship" },
        { "$ref": "#/$defs/couple_relationship" }
      ]
    },
    "parent_child_relationship": {
      "type": "object",
      "required": ["id", "type", "parent", "child"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "const": "ParentChild" },
        "parent": { "$ref": "#/$defs/id" },
        "child": { "$ref": "#/$defs/id" },
        "subtype": { "$ref": "enums.schema.json#/$defs/parent_subtype_recommended" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_reference" }
        }
      }
    },
    "couple_relationship": {
      "type": "object",
      "required": ["id", "type", "person1", "person2"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "const": "Couple" },
        "person1": { "$ref": "#/$defs/id" },
        "person2": { "$ref": "#/$defs/id" },
        "facts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fact" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_reference" }
        }
      }
    },
    "source_description": {
      "type": "object",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string" },
        "citation": { "type": "string" },
        "author": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "source_reference": {
      "type": "object",
      "required": ["ref"],
      "additionalProperties": false,
      "properties": {
        "ref": { "$ref": "#/$defs/id" },
        "page": { "type": "string" },
        "quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "description": "GEDCOM QUAY: 0=unreliable, 1=questionable, 2=secondary evidence, 3=direct and primary evidence."
        }
      }
    }
  }
}
