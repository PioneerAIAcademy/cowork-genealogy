{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-log.schema.json",
  "title": "Cowork Genealogy multi-test run log (v2)",
  "description": "Output of one harness invocation. Wraps the per-test entries with envelope metadata (version, snapshot, model) so the run log is a self-contained, releasable artifact. See docs/plan/eval-runlog-versioning.md.",
  "type": "object",
  "required": [
    "schema_version",
    "skill",
    "version",
    "released",
    "releasable",
    "invocation",
    "timestamp",
    "harness_version",
    "model",
    "judge_prompt_hash",
    "snapshot",
    "tests",
    "totals"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 2,
      "description": "Bumped when the envelope changes shape."
    },
    "skill": { "type": "string" },
    "version": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ],
      "description": "Monotonic version number assigned to releasable candidate runs. Null for scratch runs."
    },
    "released": {
      "type": "boolean",
      "description": "True once a senior renames the candidate file to v{N}.json. The harness always writes false; the CRUD UI's release action flips it to true."
    },
    "releasable": {
      "type": "boolean",
      "description": "True iff the invocation was a full --skill run with no --tag or --test filter."
    },
    "invocation": {
      "enum": ["skill", "test", "tag"],
      "description": "The CLI selection mode that produced this run log."
    },
    "timestamp": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}_\\d{2}-\\d{2}-\\d{2}$",
      "description": "UTC timestamp YYYY-MM-DD_HH-MM-SS (underscore between date and time for readability)."
    },
    "harness_version": { "type": "string" },
    "model": { "type": "string" },
    "judge_prompt_hash": {
      "type": "string",
      "pattern": "^([a-f0-9]{64})?$",
      "description": "SHA-256 of eval/harness/judge/prompt.md after normalization. Empty when the judge prompt file is missing. Not part of the snapshot — the judge prompt is project-global, tracked separately so judge edits don't clobber every skill on activate."
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "{repo-relative-path: normalized-content} of all skill-side files needed to reproduce this run. Includes packages/engine/plugin/skills/<skill>/**, eval/tests/unit/<skill>/**, and referenced scenarios + fixtures."
    },
    "tests": {
      "type": "array",
      "items": { "$ref": "#/$defs/test_entry" }
    },
    "totals": { "$ref": "#/$defs/totals" }
  },
  "$defs": {
    "test_entry": {
      "type": "object",
      "required": [
        "test_id",
        "test_type",
        "expected_outcome",
        "scenario",
        "mcp_fixtures",
        "outcome",
        "flaky",
        "outcome_summary",
        "totals",
        "runs"
      ],
      "additionalProperties": false,
      "properties": {
        "test_id": { "type": "string", "pattern": "^ut_" },
        "test_type": { "enum": ["positive", "negative"] },
        "expected_outcome": { "enum": ["pass", "xfail"] },
        "scenario": { "type": ["string", "null"] },
        "mcp_fixtures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outcome": {
          "enum": ["pass", "partial", "fail", "aborted", "xfail", "xpass"]
        },
        "flaky": { "type": "boolean" },
        "outcome_summary": {
          "type": "object",
          "required": ["per_run_outcomes", "aggregated_dimensions"],
          "additionalProperties": false,
          "properties": {
            "per_run_outcomes": {
              "type": "array",
              "items": { "enum": ["pass", "partial", "fail", "aborted"] }
            },
            "aggregated_dimensions": {
              "type": "array",
              "items": { "$ref": "#/$defs/judge_dimension" }
            }
          }
        },
        "totals": { "$ref": "#/$defs/test_totals" },
        "runs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/run" }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "duration_ms",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "judge_input_tokens",
        "judge_cached_input_tokens",
        "judge_output_tokens",
        "skill_cost_usd",
        "judge_cost_usd",
        "total_cost_usd"
      ],
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "judge_input_tokens": { "type": "integer", "minimum": 0 },
        "judge_cached_input_tokens": { "type": "integer", "minimum": 0 },
        "judge_output_tokens": { "type": "integer", "minimum": 0 },
        "skill_cost_usd": { "type": "number", "minimum": 0 },
        "judge_cost_usd": { "type": "number", "minimum": 0 },
        "total_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "test_totals": {
      "type": "object",
      "required": [
        "duration_ms",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "judge_input_tokens",
        "judge_cached_input_tokens",
        "judge_output_tokens",
        "skill_cost_usd",
        "judge_cost_usd",
        "total_cost_usd"
      ],
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "judge_input_tokens": { "type": "integer", "minimum": 0 },
        "judge_cached_input_tokens": { "type": "integer", "minimum": 0 },
        "judge_output_tokens": { "type": "integer", "minimum": 0 },
        "skill_cost_usd": { "type": "number", "minimum": 0 },
        "judge_cost_usd": { "type": "number", "minimum": 0 },
        "total_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "run": {
      "type": "object",
      "required": [
        "run_index",
        "run_id",
        "outcome",
        "aborted_reason",
        "duration_ms",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "skill_cost_usd",
        "output",
        "validators",
        "judge"
      ],
      "additionalProperties": false,
      "properties": {
        "run_index": { "type": "integer", "minimum": 0 },
        "run_id": { "type": "string" },
        "outcome": { "enum": ["pass", "partial", "fail", "aborted"] },
        "aborted_reason": {
          "anyOf": [
            {
              "enum": [
                "max_turns",
                "max_wall_clock_seconds",
                "max_tool_calls",
                "max_input_tokens_per_turn",
                "sdk_stream_silence",
                "not_runnable",
                "unmatched_tool_call",
                "error"
              ]
            },
            { "type": "null" }
          ]
        },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "skill_cost_usd": { "type": "number", "minimum": 0 },
        "output": { "$ref": "#/$defs/run_output" },
        "validators": { "$ref": "#/$defs/validator_results" },
        "judge": { "$ref": "#/$defs/judge_results" }
      }
    },
    "run_output": {
      "type": "object",
      "required": [
        "text_response",
        "activated",
        "skills_invoked",
        "tool_calls",
        "files_created"
      ],
      "additionalProperties": false,
      "properties": {
        "activated": { "type": "boolean" },
        "text_response": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["ref"],
              "additionalProperties": false,
              "properties": { "ref": { "type": "string" } }
            }
          ]
        },
        "skills_invoked": {
          "type": "array",
          "items": { "type": "string" }
        },
        "file_changes": {
          "type": ["object", "null"],
          "additionalProperties": { "$ref": "#/$defs/file_diff" }
        },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool_call" }
        },
        "files_created": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind"],
            "additionalProperties": true,
            "properties": { "kind": { "type": "string" } }
          }
        }
      }
    },
    "file_diff": {
      "type": "object",
      "required": ["sections_modified", "diff"],
      "additionalProperties": false,
      "properties": {
        "sections_modified": {
          "type": "array",
          "items": { "type": "string" }
        },
        "diff": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/section_diff" }
        }
      }
    },
    "section_diff": {
      "type": "object",
      "required": ["added", "modified", "deleted"],
      "additionalProperties": false,
      "properties": {
        "added": { "type": "array", "items": { "type": "object" } },
        "modified": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "changed_fields"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "changed_fields": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["before", "after"],
                  "additionalProperties": false,
                  "properties": { "before": {}, "after": {} }
                }
              }
            }
          }
        },
        "deleted": { "type": "array", "items": { "type": "object" } }
      }
    },
    "tool_call": {
      "type": "object",
      "required": ["tool", "args", "expected_args", "matched", "response_fixture"],
      "additionalProperties": false,
      "properties": {
        "tool": { "type": "string" },
        "args": { "type": "object" },
        "expected_args": {
          "anyOf": [{ "type": "object" }, { "type": "null" }],
          "description": "The `args` block from the matched fixture (canonical expected args). Null when no fixture matched (e.g., fixture_not_found)."
        },
        "matched": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["predicate", "none", "live"] },
            "index": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "response_fixture": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "description": "Invariant: matched.kind == 'predicate' ↔ expected_args is an object and response_fixture is a string.",
          "if": {
            "properties": { "matched": { "properties": { "kind": { "const": "predicate" } } } }
          },
          "then": {
            "properties": {
              "expected_args": { "type": "object" },
              "response_fixture": { "type": "string" }
            }
          }
        },
        {
          "description": "Invariant: matched.kind == 'none' ↔ expected_args is null and response_fixture is null.",
          "if": {
            "properties": { "matched": { "properties": { "kind": { "const": "none" } } } }
          },
          "then": {
            "properties": {
              "expected_args": { "type": "null" },
              "response_fixture": { "type": "null" }
            }
          }
        },
        {
          "description": "Invariant: matched.kind == 'live' ↔ expected_args is null and response_fixture is a string (live handler name).",
          "if": {
            "properties": { "matched": { "properties": { "kind": { "const": "live" } } } }
          },
          "then": {
            "properties": {
              "expected_args": { "type": "null" },
              "response_fixture": { "type": "string" }
            }
          }
        }
      ]
    },
    "validator_results": {
      "type": "object",
      "required": ["passed", "results"],
      "additionalProperties": false,
      "properties": {
        "passed": {
          "anyOf": [{ "type": "boolean" }, { "type": "null" }]
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "passed"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "passed": { "type": "boolean" },
              "error": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "judge_results": {
      "type": "object",
      "required": ["skipped", "dimensions", "judge_cost_usd"],
      "additionalProperties": false,
      "properties": {
        "skipped": { "type": "boolean" },
        "dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/judge_dimension" }
        },
        "judge_cost_usd": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "error": { "type": ["string", "null"] }
      }
    },
    "judge_dimension": {
      "type": "object",
      "required": ["source", "name", "score", "rationale"],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": ["base", "rubric"] },
        "name": { "type": "string" },
        "score": {
          "anyOf": [
            { "enum": [1, 2, 3] },
            { "type": "null" }
          ],
          "description": "1=fail, 2=partial, 3=pass. Null = N/A, currently allowed only on the Tool Arguments base dimension when a test makes zero MCP tool calls."
        },
        "rationale": { "type": "string" }
      }
    }
  }
}
