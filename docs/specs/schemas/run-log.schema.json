{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-log.schema.json",
  "title": "GeneFun Unit Test Run Log",
  "description": "Output of one harness execution of one test (covering N runs, where N is runs_per_test). See docs/specs/unit-test-spec.md Section 10.",
  "type": "object",
  "required": [
    "test_id",
    "skill",
    "test_type",
    "expected_outcome",
    "timestamp",
    "harness_version",
    "model",
    "judge_model",
    "rubric_hash",
    "judge_prompt_hash",
    "scenario",
    "mcp_fixtures",
    "outcome",
    "flaky",
    "outcome_summary",
    "totals",
    "runs"
  ],
  "additionalProperties": false,
  "properties": {
    "test_id": {
      "type": "string",
      "pattern": "^ut_",
      "description": "References the test JSON."
    },
    "skill": { "type": "string" },
    "test_type": { "enum": ["positive", "negative"] },
    "expected_outcome": {
      "enum": ["pass", "xfail"],
      "description": "Echoed from the test JSON."
    },
    "timestamp": { "$ref": "enums.schema.json#/$defs/iso_datetime" },
    "harness_version": {
      "type": "string",
      "description": "Semver of the harness package at run time. Bumping the harness invalidates apples-to-apples comparison with prior runs."
    },
    "model": {
      "type": "string",
      "description": "Pinned model version used to execute the skill."
    },
    "judge_model": {
      "type": "string",
      "description": "Model used by the LLM judge."
    },
    "rubric_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of eval/tests/unit/<skill>/rubric.md at run time."
    },
    "judge_prompt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of eval/harness/judge/prompt.md at run time."
    },
    "scenario": { "type": ["string", "null"] },
    "mcp_fixtures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outcome": {
      "enum": ["pass", "partial", "fail", "aborted", "xfail", "xpass"],
      "description": "Aggregated outcome across all runs (modal with ties tie-breaking down). xfail = xfail-marked test that failed (expected, not a regression). xpass = xfail-marked test that passed (unexpected; marker may be stale). Matches pytest convention. flaky is a separate boolean flag, not an outcome value."
    },
    "flaky": {
      "type": "boolean",
      "description": "True when per-run outcomes are not unanimous. Composes orthogonally with outcome — a test can be outcome:pass + flaky:true."
    },
    "outcome_summary": {
      "type": "object",
      "required": ["per_run_outcomes", "aggregated_dimensions"],
      "additionalProperties": false,
      "properties": {
        "per_run_outcomes": {
          "type": "array",
          "items": { "enum": ["pass", "partial", "fail", "aborted"] }
        },
        "aggregated_dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/judge_dimension" }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "duration_ms",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "skill_cost_usd",
        "judge_cost_usd",
        "total_cost_usd"
      ],
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Input tokens served from the prompt cache. Should be 70%+ of input_tokens for N>1 batched runs; lower means caching isn't firing."
        },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "skill_cost_usd": { "type": "number", "minimum": 0 },
        "judge_cost_usd": { "type": "number", "minimum": 0 },
        "total_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/run" }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "required": [
        "run_index",
        "run_id",
        "outcome",
        "aborted_reason",
        "duration_ms",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "skill_cost_usd",
        "output",
        "validators",
        "judge"
      ],
      "additionalProperties": false,
      "properties": {
        "run_index": { "type": "integer", "minimum": 0 },
        "run_id": { "type": "string" },
        "outcome": { "enum": ["pass", "partial", "fail", "aborted"] },
        "aborted_reason": {
          "anyOf": [
            {
              "enum": [
                "max_turns",
                "max_wall_clock_seconds",
                "max_tool_calls",
                "max_input_tokens_per_turn",
                "not_runnable"
              ]
            },
            { "type": "null" }
          ]
        },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "skill_cost_usd": { "type": "number", "minimum": 0 },
        "output": { "$ref": "#/$defs/run_output" },
        "validators": { "$ref": "#/$defs/validator_results" },
        "judge": { "$ref": "#/$defs/judge_results" }
      }
    },
    "run_output": {
      "type": "object",
      "required": ["text_response", "activated", "skills_invoked", "tool_calls", "files_created"],
      "additionalProperties": false,
      "properties": {
        "activated": {
          "type": "boolean",
          "description": "Derived from unit-test-spec.md Section 6 rules. True if the skill under test substantively activated (owned-section writes, characteristic tool calls, file changes, or skill invocation with substantive output)."
        },
        "text_response": {
          "anyOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["ref"],
              "additionalProperties": false,
              "properties": {
                "ref": {
                  "type": "string",
                  "description": "Relative path to a sidecar markdown file when the response exceeds 100 KB."
                }
              }
            }
          ]
        },
        "skills_invoked": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skill directory names invoked during this run, in invocation order."
        },
        "file_changes": {
          "type": ["object", "null"],
          "additionalProperties": { "$ref": "#/$defs/file_diff" }
        },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool_call" }
        },
        "files_created": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "file_diff": {
      "type": "object",
      "required": ["sections_modified", "diff"],
      "additionalProperties": false,
      "properties": {
        "sections_modified": {
          "type": "array",
          "items": { "type": "string" }
        },
        "diff": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/section_diff" }
        }
      }
    },
    "section_diff": {
      "type": "object",
      "required": ["added", "modified", "deleted"],
      "additionalProperties": false,
      "properties": {
        "added": {
          "type": "array",
          "items": { "type": "object" }
        },
        "modified": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "changed_fields"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "changed_fields": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["before", "after"],
                  "additionalProperties": false,
                  "properties": {
                    "before": {},
                    "after": {}
                  }
                }
              }
            }
          }
        },
        "deleted": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Should always be empty if validators pass (no-delete enforcement)."
        }
      }
    },
    "tool_call": {
      "type": "object",
      "required": ["tool", "args", "matched", "response_fixture"],
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "string",
          "description": "Full tool name, e.g. mcp__genealogy__record_search."
        },
        "args": { "type": "object" },
        "matched": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["predicate", "queue", "none"] },
            "index": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "response_fixture": { "type": ["string", "null"] }
      }
    },
    "validator_results": {
      "type": "object",
      "required": ["passed", "results"],
      "additionalProperties": false,
      "properties": {
        "passed": { "type": "boolean" },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "passed"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "passed": { "type": "boolean" },
              "error": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "judge_results": {
      "type": "object",
      "required": ["skipped", "dimensions", "judge_cost_usd"],
      "additionalProperties": false,
      "properties": {
        "skipped": { "type": "boolean" },
        "dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/judge_dimension" }
        },
        "judge_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "judge_dimension": {
      "type": "object",
      "required": ["source", "name", "score", "rationale"],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": ["base", "rubric", "criteria"] },
        "name": { "type": "string" },
        "score": { "enum": ["pass", "partial", "fail"] },
        "rationale": { "type": "string" }
      }
    }
  }
}
