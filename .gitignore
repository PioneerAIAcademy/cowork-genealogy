node_modules/
packages/engine/mcp-server/build/

# Local Claude Code MCP-server registration. Machine-specific: it hardcodes
# an absolute path to the local build output, so it's never portable across
# checkouts. Per-developer dev config, not project state.
packages/engine/mcp-server/.mcp.json

# Stale top-level mcp-server/ left over from before the monorepo refactor
# (PR #293 moved mcp-server to packages/engine/mcp-server). The leading slash
# anchors this to the repo root so it does NOT match packages/engine/mcp-server.
/mcp-server/

releases/*
!releases/.gitkeep
*.log
.DS_Store
.env
.claude/*
!.claude/commands/
!.claude/agents/
!.claude/skills/
local/
.local/
personal/
.tool-versions

# Eval CRUD UI (eval/app/) — populated by step 1 of the plan
eval/app/lib/schema/

# Scratch run logs — partial/--test/--all/--tag harness invocations.
# Never released; junior dev's local debugging only. See
# docs/plan/eval-runlog-versioning.md §A1, §A3.
eval/runlogs/unit/*/scratch_*.json
eval/runlogs/unit/*/scratch_*.ann.json

# Description-optimizer output (make optimize-skill). Regenerable; runlogs/optimizer
# is excluded from the release gate + comparisons (eval/CLAUDE.md).
eval/runlogs/optimizer/*
!eval/runlogs/optimizer/.gitkeep

# Playwright test artifacts.
eval/app/test-results/
eval/app/playwright-report/

# gstack tool runtime data (not project state).
.gstack/

# Build artifacts that shouldn't be committed (in case of `git add .`).
.next/
*.tsbuildinfo
coverage/

# Web capture evaluation (local research, not committed).
docs/web-capture-eval/

# ── Hosted web workbench (monorepo) ──────────────────────────────
.turbo/
dist/
out/
apps/web/dist/
packages/*/dist/
# FastAPI control plane: venv, SQLite DB, local env, bytecode
apps/server/.venv/
apps/server/*.db
apps/server/*.db-journal
apps/server/.env
__pycache__/
*.pyc
# LocalProvider mock sandbox project dirs + local viewer backup mirror
.workbench-data/
