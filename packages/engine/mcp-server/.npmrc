# Fail `npm install` / `npm ci` when Node or npm fall outside package.json
# "engines" (node >=22, npm >=11.12 <12). npm reads only this directory's
# .npmrc, not the repo-root one, since the engine lives outside the pnpm
# workspace and is managed with plain npm.
#
# The npm bound is the load-bearing part: older npm (e.g. 11.7.0) re-normalizes
# package-lock.json — it strips the `libc` tags on rolldown's optional binaries
# (@rolldown/binding-linux-*) — producing spurious lockfile churn. engine-strict
# turns the engines declaration into a hard local stop, so a divergent npm is
# caught on the developer's machine, not just by check-engine-lockfile in CI.
# Get the pinned npm with `corepack enable` (reads packageManager in package.json).
engine-strict=true
