# Hoisted node_modules layout so electron-builder / electron-vite and the
# engine's own npm tooling behave exactly as they do with plain npm.
node-linker=hoisted
shamefully-hoist=true

# Fail install on Node older than package.json "engines" (>=22). The test
# tooling needs Node 22 (vitest/rolldown use node:util styleText); without
# this, a wrong Node version only surfaces as cryptic runtime errors.
engine-strict=true
